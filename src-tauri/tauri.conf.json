{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ollama Pet",
  "version": "0.0.1",
  "identifier": "com.amvk2.ollama-pet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ollama Pet",
        "width": 120,
        "height": 120,
        "center": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "chat",
        "title": "Ollama Pet Chat",
        "width": 320,
        "height": 380,
        "center": true,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "minWidth": 260,
        "minHeight": 260,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
